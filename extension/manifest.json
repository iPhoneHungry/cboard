{
  "manifest_version": 3,
  "name": "cboard clipper",
  "version": "0.1.2",
  "description": "Annotate the current page and file it as a cboard ticket — screenshot, notes, and repro steps — straight to your local board over MCP.",
  "permissions": ["activeTab", "tabs", "storage", "scripting"],
  "host_permissions": ["http://localhost:8787/*", "http://127.0.0.1:8787/*"],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_title": "Report to cboard" },
  "icons": { "16": "icons/icon-16.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" },
  "content_scripts": [
    { "matches": ["<all_urls>"], "js": ["recorder.js"], "run_at": "document_idle", "all_frames": false }
  ]
}
